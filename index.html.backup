<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Robinson Diaz — Product Listing & Ad Creative Specialist</title>
  <style>
    :root {
      --bg: #0B0B0B;
      --surface: #111111;
      --surface-2: #171717;
      --text: #F5F5F5;
      --muted: #BDBDBD;
      --line: rgba(255,255,255,0.1);
      --soft: rgba(255,255,255,0.04);
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: var(--bg);
      color: var(--text);
      overflow-x: hidden;
    }
    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      opacity: .06;
      background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0);
      background-size: 26px 26px;
    }
    body::after {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      background:
        radial-gradient(circle at 70% 10%, rgba(255,255,255,0.12), transparent 32%),
        radial-gradient(circle at 10% 20%, rgba(255,255,255,0.08), transparent 30%);
    }
    a { color: inherit; text-decoration: none; }
    button { font: inherit; cursor: pointer; color: inherit; }
    .loader {
      position: fixed; inset: 0; z-index: 999;
      display: flex; align-items: center; justify-content: center;
      background: var(--bg);
      transition: opacity .8s ease, visibility .8s ease;
    }
    .loader.hide { opacity: 0; visibility: hidden; }
    .loader p { font-size: 11px; letter-spacing: .6em; text-transform: uppercase; color: rgba(255,255,255,.4); }
    .loader h1 { margin-top: 20px; text-align:center; font-size: 72px; font-weight: 300; letter-spacing: -.08em; }
    .progress { position: fixed; left:0; top:0; height: 3px; width:0; background: rgba(255,255,255,.85); z-index: 998; }
    .nav {
      position: fixed; left:50%; top:20px; transform: translateX(-50%); z-index: 80;
      display:flex; gap:4px; align-items:center; padding:8px 12px;
      border:1px solid var(--line); background: rgba(0,0,0,.35); backdrop-filter: blur(24px);
      border-radius:999px;
    }
    .nav a { padding:10px 14px; border-radius:999px; font-size:11px; letter-spacing:.2em; text-transform:uppercase; color:rgba(255,255,255,.55); transition:.35s; }
    .nav a:hover { color:#fff; background:rgba(255,255,255,.09); }
    .page { position: relative; z-index: 2; }
    .hero {
      min-height:100vh; display:grid; grid-template-columns:1.1fr .9fr; gap:48px; align-items:center;
      padding:130px 7vw 80px;
    }
    .eyebrow { margin-bottom:20px; font-size:11px; letter-spacing:.48em; text-transform:uppercase; color:rgba(255,255,255,.45); }
    .hero-title { font-size: clamp(76px, 11vw, 180px); line-height:.75; letter-spacing:-.12em; text-transform:uppercase; font-weight:700; position:relative; }
    .year { position:absolute; top:8px; right:8%; border:1px solid rgba(255,255,255,.15); border-radius:999px; padding:8px 14px; font-size:11px; letter-spacing:.25em; color:rgba(255,255,255,.55); }
    .hero h2 { margin-top:38px; font-size: clamp(36px, 4vw, 72px); font-weight:300; letter-spacing:-.06em; }
    .subtitle { margin-top:12px; font-size:20px; color:rgba(255,255,255,.72); }
    .desc { margin-top:24px; max-width:650px; color: var(--muted); line-height:1.9; font-size:17px; }
    .actions { display:flex; flex-wrap:wrap; gap:16px; margin-top:36px; }
    .btn {
      position:relative; overflow:hidden; border:none; border-radius:999px; padding:14px 26px;
      text-transform:uppercase; letter-spacing:.18em; font-size:12px; transition:.35s;
    }
    .btn.primary { background:white; color:black; box-shadow:0 0 42px rgba(255,255,255,.18); }
    .btn.secondary { background:rgba(255,255,255,.03); color:white; border:1px solid rgba(255,255,255,.15); backdrop-filter: blur(18px); }
    .btn:hover { transform: translateY(-3px); }
    .portrait-wrap { position:relative; max-width:520px; margin:auto; width:100%; }
    .portrait-glow { position:absolute; inset:-32px; border-radius:48px; background:rgba(255,255,255,.10); filter: blur(48px); }
    .portrait {
      position:relative;
      aspect-ratio:4/5;
      overflow:hidden;
      border-radius:42px;
      border:1px solid rgba(255,255,255,.15);
      background:#111;
      box-shadow:0 30px 80px rgba(0,0,0,.6);
    }
    .portrait-img{
      width:100%;
      height:100%;
      object-fit:cover;
      display:block;
      filter: grayscale(100%);
    }
    .portrait::before { content:""; position:absolute; inset:0; background: radial-gradient(circle at 50% 22%, rgba(255,255,255,.35), transparent 18%), linear-gradient(140deg, rgba(255,255,255,.12), transparent 45%); }
    .portrait-shape { position:absolute; left:14%; right:14%; bottom:0; height:70%; border-radius:45% 45% 0 0; border:1px solid rgba(255,255,255,.15); background:linear-gradient(to bottom, rgba(255,255,255,.18), rgba(0,0,0,.2)); }
    .portrait-note { position:absolute; left:28px; right:28px; bottom:28px; border:1px solid rgba(255,255,255,.1); background:rgba(0,0,0,.35); backdrop-filter:blur(18px); border-radius:26px; padding:20px; color:rgba(255,255,255,.75); }
    section { padding:110px 7vw; }
    .border-section { border-top:1px solid var(--line); border-bottom:1px solid var(--line); }
    .section-title { font-size: clamp(48px, 6vw, 92px); line-height:.95; letter-spacing:-.07em; font-weight:300; }
    .about-grid { display:grid; grid-template-columns:.9fr 1.1fr; gap:60px; }
    .body-copy { color:var(--muted); font-size:18px; line-height:1.9; display:grid; gap:24px; }
    .section-head { display:flex; justify-content:space-between; align-items:end; gap:32px; margin-bottom:48px; }
    .section-head p { max-width:380px; color:rgba(255,255,255,.45); line-height:1.8; }
    .services-grid { display:grid; grid-template-columns:.85fr 1.15fr; gap:24px; }
    .service-list { display:grid; gap:12px; }
    .service-btn {
      width:100%; display:flex; justify-content:space-between; align-items:center; gap:20px; text-align:left;
      border:1px solid var(--line); background:rgba(255,255,255,.025); border-radius:28px; padding:20px; transition:.45s;
    }
    .service-btn:hover, .service-btn.active { border-color:rgba(255,255,255,.35); background:rgba(255,255,255,.085); box-shadow:0 0 45px rgba(255,255,255,.06); transform: translateY(-2px); }
    .service-icon { width:48px; height:48px; display:grid; place-items:center; border:1px solid var(--line); border-radius:18px; background:rgba(0,0,0,.28); }
    .service-kicker { display:block; font-size:11px; letter-spacing:.22em; text-transform:uppercase; color:rgba(255,255,255,.42); margin-bottom:6px; }
    .service-title { font-size:17px; }
    .spotlight {
      position:relative; overflow:hidden; border:1px solid var(--line); background:rgba(255,255,255,.035); backdrop-filter: blur(20px); border-radius:34px;
    }
    .showcase { min-height:620px; padding:30px; transition:.45s; }
    .showcase-visual { position:relative; aspect-ratio:16/9; border-radius:28px; overflow:hidden; border:1px solid var(--line); background:#111; margin-bottom:32px; }
    .showcase-visual::before { content:""; position:absolute; inset:0; background: radial-gradient(circle at 40% 30%, rgba(255,255,255,.22), transparent 24%), linear-gradient(135deg, rgba(255,255,255,.12), transparent 45%); }
    .visual-label { position:absolute; left:28px; bottom:24px; font-size: clamp(52px, 7vw, 104px); font-weight:700; letter-spacing:-.08em; }
    .floating-badge { position:absolute; left:28px; top:28px; border:1px solid var(--line); background:rgba(0,0,0,.35); backdrop-filter:blur(20px); border-radius:24px; padding:18px; animation: float 5s ease-in-out infinite; }
    @keyframes float { 0%,100%{ transform: translateY(0);} 50%{ transform: translateY(-10px);} }
    .showcase h3 { font-size: clamp(34px, 4vw, 58px); font-weight:300; letter-spacing:-.05em; }
    .showcase p { margin-top:18px; max-width:760px; color:var(--muted); line-height:1.85; }
    .metric-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:14px; margin-top:28px; }
    .metric { border:1px solid var(--line); background:rgba(0,0,0,.2); border-radius:18px; padding:16px; color:rgba(255,255,255,.7); font-size:14px; }
    .pills { display:flex; flex-wrap:wrap; gap:10px; margin-top:26px; }
    .pill { border:1px solid var(--line); background:rgba(255,255,255,.04); border-radius:999px; padding:9px 14px; font-size:11px; letter-spacing:.18em; text-transform:uppercase; color:rgba(255,255,255,.58); }
    .filters { display:flex; flex-wrap:wrap; gap:12px; margin-top:42px; }
    .filter-btn { border:1px solid var(--line); background:rgba(255,255,255,.025); border-radius:999px; padding:12px 18px; font-size:11px; letter-spacing:.18em; text-transform:uppercase; color:rgba(255,255,255,.55); transition:.3s; }
    .filter-btn.active, .filter-btn:hover { background:white; color:black; border-color:white; }
    .work-grid {
      margin-top:48px;
      display:flex;
      gap:20px;
      overflow-x:auto;
      padding-bottom:12px;
      scroll-snap-type:x mandatory;
      -webkit-overflow-scrolling:touch;
    }
    .work-grid::-webkit-scrollbar { height:10px; }
    .work-grid::-webkit-scrollbar-track { background: transparent; }
    .work-grid::-webkit-scrollbar-thumb { background: rgba(255,255,255,.12); border-radius:999px; }
    .work-card {
      min-width:320px;
      flex:0 0 320px;
      padding:16px;
      text-align:left;
      transition: transform .4s ease, box-shadow .4s ease;
      scroll-snap-align:start;
    }
    .work-card:hover { transform: translateY(-8px) scale(1.01); }
    .work-image { position:relative; aspect-ratio:4/3; border-radius:24px; border:1px solid var(--line); overflow:hidden; background: radial-gradient(circle at 50% 20%, rgba(255,255,255,.2), transparent 25%), linear-gradient(135deg, rgba(255,255,255,.12), transparent 52%); display:flex; align-items:center; justify-content:center; padding:0; transition:.5s; }
    .work-image .pill { position:absolute; left:18px; bottom:18px; z-index:2; max-width:calc(100% - 36px); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; padding:8px 12px; background:rgba(0,0,0,.65); border:1px solid rgba(255,255,255,.08); }
    .gallery-img{width:100%; height:100%; object-fit:contain; object-position:center; display:block; }
    .work-card:hover .work-image { transform: scale(1.015); }
    .work-card h3 { margin:14px 8px 0; font-size:24px; font-weight:300; letter-spacing:-.04em; }
    .work-card .cat { margin:20px 8px 0; color:rgba(255,255,255,.36); font-size:11px; text-transform:uppercase; letter-spacing:.28em; }
    .tools-grid { margin-top:48px; display:grid; grid-template-columns:repeat(5,1fr); gap:18px; }
    .tool-box { padding:22px; min-height:170px; }
    .tool-box h3 { color:rgba(255,255,255,.45); font-size:12px; letter-spacing:.24em; text-transform:uppercase; line-height:1.6; }
    .tool-box .pills .pill { font-size:13px; letter-spacing:0; text-transform:none; transition:.3s; }
    .tool-box .pill:hover { transform: translateY(-4px); border-color:rgba(255,255,255,.35); color:white; }
    .contact-card { padding:50px; }
    .contact-grid { display:grid; grid-template-columns:1.1fr .9fr; gap:60px; }
    .contact-links { display:grid; align-content:end; gap:12px; }
    .contact-link { display:flex; justify-content:space-between; align-items:center; gap:20px; border:1px solid var(--line); background:rgba(0,0,0,.2); border-radius:20px; padding:16px; transition:.3s; }
    .contact-link:hover { border-color:rgba(255,255,255,.35); background:rgba(255,255,255,.06); transform: translateX(4px); }
    .contact-link small { display:block; color:rgba(255,255,255,.36); text-transform:uppercase; letter-spacing:.24em; font-size:10px; margin-bottom:5px; }
    .modal { position:fixed; inset:0; z-index:120; display:none; align-items:center; justify-content:center; padding:20px; background:rgba(0,0,0,.72); backdrop-filter:blur(24px); }
    .modal.show { display:flex; }
    .modal-card { width:100%; max-width:1000px; border:1px solid var(--line); background:#111; border-radius:32px; padding:26px; position:relative; animation: modalIn .35s ease both; max-height:90vh; overflow-y:auto; }
    .modal-back { position:absolute; left:18px; top:18px; border:1px solid var(--line); border-radius:999px; background:rgba(255,255,255,.05); width:38px; height:38px; display:grid; place-items:center; opacity:0.9; cursor:pointer; transition:.25s ease; }
    .modal-back:hover { background:rgba(255,255,255,.12); }
    .product-gallery-grid { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:18px; margin-top:24px; }
    .product-gallery-card { display:flex; flex-direction:column; border:1px solid rgba(255,255,255,.12); border-radius:26px; overflow:hidden; background:rgba(255,255,255,.02); cursor:pointer; transition:.35s; text-align:left; }
    .product-gallery-card:hover { transform: translateY(-4px); border-color:rgba(255,255,255,.25); }
    .product-gallery-cover { width:100%; aspect-ratio:4/3; overflow:hidden; background:#111; }
    /* Recommended image ratio: 4:3 */
    .product-gallery-cover img { width:100%; height:100%; object-fit:cover; object-position:center; display:block; }
    .product-gallery-copy { padding:18px; display:grid; gap:10px; }
    .product-gallery-copy h4 { font-size:16px; font-weight:600; letter-spacing:-.03em; }
    .product-gallery-copy p { color:rgba(255,255,255,.6); font-size:14px; line-height:1.7; }
    .product-gallery-copy .pill { margin-top:10px; align-self:start; }
    .modal-empty-state { display:grid; place-items:center; min-height:280px; text-align:center; gap:14px; color:rgba(255,255,255,.7); }
    .modal-empty-state h4 { font-size:22px; font-weight:400; }
    .modal-empty-state p { max-width:420px; margin:0 auto; color:rgba(255,255,255,.55); }
    @keyframes modalIn { from { opacity:0; transform: translateY(25px) scale(.97);} to { opacity:1; transform:none;} }
    .close { position:absolute; right:18px; top:18px; border:1px solid var(--line); border-radius:999px; background:transparent; width:38px; height:38px; }
    /* GALLERY BOARD CONTAINER - Pinterest/Instagram style scrolling board */
    .modal-img { position:relative; max-height:75vh; overflow:hidden; border-radius:24px; border:1px solid var(--line); background:#0a0a0a; padding:0; margin:24px 0; }
    .modal-gallery-container { position:relative; width:100%; height:100%; }
    /* AUTO-SCROLL SPEED SETTINGS */
    /* Change these values to adjust gallery scroll speed */
    /* @keyframes scrollSpeed: Higher 'to' value = slower scroll, Lower 'to' value = faster scroll */
    @keyframes scrollBoard {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .modal-gallery { 
      display:flex; 
      gap:20px; 
      width:200%; 
      height:400px; 
      overflow:hidden; 
      padding:20px; 
      /* AUTO-SCROLL SPEED SETTINGS */
      animation: scrollBoard 45s linear infinite; 
      /* To pause animation on hover, see JS: pauseGalleryScroll() function */
    }
    .modal-gallery.paused {
      animation-play-state: paused;
    }
    /* GALLERY IMAGE CARDS - Medium-sized portfolio board cards */
    .modal-slide { 
      flex:0 0 240px; 
      width:240px; 
      height:100%; 
      overflow:hidden; 
      border-radius:16px; 
      border:1px solid rgba(255,255,255,.12); 
      background:#0f0f0f; 
      cursor:pointer; 
      transition:.3s ease;
      box-shadow:0 8px 32px rgba(0,0,0,.4);
    }
    .modal-slide:hover { 
      border-color:rgba(255,255,255,.25); 
      box-shadow:0 12px 48px rgba(0,0,0,.6);
      transform:scale(1.02);
    }
    .modal-real-img { 
      width:100%; 
      height:100%; 
      object-fit:cover; 
      object-position:center; 
      display:block; 
    }
    /* LIGHTBOX PREVIEW - Enlarged image preview with full visibility */
    .lightbox { position:fixed; inset:0; z-index:999; display:none; align-items:center; justify-content:center; padding:20px; background:rgba(0,0,0,.88); backdrop-filter:blur(32px); }
    .lightbox.show { display:flex; }
    .lightbox-content { position:relative; max-width:90vw; max-height:90vh; width:100%; animation: modalIn .3s ease both; }
    .lightbox-image { 
      width:100%; 
      height:100%; 
      object-fit:contain; 
      object-position:center; 
      display:block; 
      border-radius:20px; 
      border:1px solid rgba(255,255,255,.15);
      background:#0a0a0a;
    }
    /* LIGHTBOX PREVIEW SETTINGS */
    /* Lightbox max-width/max-height can be adjusted above for different image sizes */
    .lightbox-close { 
      position:absolute; 
      right:-50px; 
      top:-50px; 
      border:1px solid var(--line); 
      border-radius:999px; 
      background:rgba(255,255,255,.08); 
      color:white; 
      width:42px; 
      height:42px; 
      font-size:24px; 
      display:grid; 
      place-items:center; 
      cursor:pointer; 
      transition:.25s ease; 
    }
    .lightbox-close:hover { background:rgba(255,255,255,.18); }
    @media (max-width:768px) {
      .lightbox-close { right:-38px; top:-38px; width:36px; height:36px; font-size:20px; }
      .lightbox-image { border-radius:12px; }
    }
    .modal-arrow { position:absolute; top:50%; transform:translateY(-50%); border:none; background:rgba(255,255,255,.08); color:white; width:42px; height:42px; border-radius:999px; display:grid; place-items:center; cursor:pointer; transition:.25s ease; }
    .modal-arrow:hover { background:rgba(255,255,255,.18); }
    .modal-arrow.prev { left:14px; }
    .modal-arrow.next { right:14px; }
    .modal-indicators { display:flex; justify-content:center; gap:10px; margin-top:16px; }
    .modal-indicators span { width:10px; height:10px; border-radius:999px; background:rgba(255,255,255,.18); transition: background .25s ease, transform .25s ease; }
    .modal-indicators span.active { background:#fff; transform:scale(1.2); }
    .modal-card h3 { margin-top:18px; font-size:42px; font-weight:300; letter-spacing:-.05em; }
    .modal-card p { margin-top:14px; color:var(--muted); line-height:1.8; }
    .reveal { opacity:0; transform: translateY(40px); transition: opacity .8s ease, transform .8s ease; }
    .reveal.show { opacity:1; transform:none; }
    @media (max-width: 980px) {
      .hero, .about-grid, .services-grid, .contact-grid { grid-template-columns:1fr; }
      .section-head { display:block; }
      .section-head p { margin-top:20px; }
      .work-grid { grid-template-columns:1fr 1fr; }
      .tools-grid { grid-template-columns:1fr 1fr; }
      .nav { display:none; }
    }
    @media (max-width: 640px) {
      .hero, section { padding-left:22px; padding-right:22px; }
      .work-grid, .tools-grid, .metric-grid { grid-template-columns:1fr; }
      .contact-card { padding:28px; }
      .hero-title { font-size:86px; }
      .year { right:0; }
    }
  </style>
</head>
<body>
  <div class="loader" id="loader"><div><p>Loading Portfolio</p><h1>RD</h1></div></div>
  <div class="progress" id="progress"></div>
  <nav class="nav">
    <a href="#about">About</a><a href="#services">Services</a><a href="#work">Work</a><a href="#tools">Tools</a><a href="#contact">Contact</a>
  </nav>
  <div class="page">
    <section class="hero">
      <div class="reveal">
        <p class="eyebrow">Premium eCommerce Operator</p>
        <div style="position:relative"><h1 class="hero-title">PORT<br>FOLIO</h1><span class="year">2026</span></div>
        <h2>Robinson Diaz</h2>
        <p class="subtitle">Shopify Storefront & AI Creative Systems Specialist</p>
        <p class="desc">I help eCommerce brands build cleaner Shopify storefronts and create AI-powered Ad creatives designed for modern conversion-focused advertising.</p>
        <div class="actions"><a class="btn primary" href="#work">View Work ↗</a><a class="btn secondary" href="#contact">Contact Me ↗</a></div>
      </div>
      <div class="portrait-wrap reveal">
        <div class="portrait-glow"></div><div class="portrait">
          <img src="rob1.jpg"
      alt="Robinson Diaz" class="portrait-img">
        </div>
      </div>
    </section>
    <section class="border-section reveal" id="about">
      <p class="eyebrow">About</p>
      <div class="about-grid"><h2 class="section-title">The System Behind the Store</h2><div class="body-copy"><p>I work at the intersection of Shopify operations, storefront clarity, and AI-powered creative production. My focus is not just making things look good — it is building eCommerce systems that feel organized, premium, and ready to convert.</p><p>From product listing and backend organization to Meta ad creative workflows, I help brands create a cleaner store experience and a more efficient creative pipeline.</p></div></div>
    </section>
    <section id="services" class="reveal">
      <p class="eyebrow">What I Do</p>
      <div class="section-head"><h2 class="section-title">Interactive Service Showcase</h2><p>Click each system to preview the strategic work behind the storefront, backend, and creative engine.</p></div>
      <div class="services-grid"><div class="service-list" id="serviceList"></div><div class="spotlight showcase" id="showcase"></div></div>
    </section>
    <section class="border-section reveal" id="work">
      <p class="eyebrow">Work</p><h2 class="section-title">Flexible Work Gallery for Every eCommerce Asset</h2><div class="filters" id="filters"></div><div class="work-grid" id="workGrid"></div>
    </section>
    <section id="tools" class="reveal">
      <p class="eyebrow">Tools</p><h2 class="section-title">The Stack Behind the System</h2><div class="tools-grid" id="toolsGrid"></div>
    </section>
    <section id="contact" class="reveal">
      <div class="spotlight contact-card"><div class="contact-grid"><div><p class="eyebrow">Contact</p><h2 class="section-title">Build the Store. Systemize the Creative.</h2><p class="desc">For Shopify product listing support, backend organization, and AI-powered Meta ad creative systems.</p></div><div class="contact-links"><a class="contact-link" href="#"><span><small>Email</small>robnsndiazzx@gmail.com</span><span>↗</span></a><a class="contact-link" href="#"><span><small>WhatsApp</small>+63 930 969 4613</span><span>↗</span></a><a class="contact-link" href="#"><span><small>OnlineJobs.ph</small>https://www.onlinejobs.ph/jobseekers/info/4890493</span><span>↗</span></a></div></div></div>
    </section>
  </div>
  <!-- LIGHTBOX PREVIEW for enlarged image viewing -->
  <div class="lightbox" id="lightbox">
    <div class="lightbox-content">
      <img src="" alt="Preview" class="lightbox-image" id="lightboxImage">
      <button class="lightbox-close" id="lightboxClose">×</button>
    </div>
  </div>
  <!-- MAIN MODAL for gallery selection and auto-scrolling board -->
  <div class="modal" id="modal">
    <div class="modal-card">
      <button class="modal-back" id="modalBack" style="display:none">← Back to Galleries</button>
      <button class="close" id="closeModal">×</button>
      <!-- AUTO-SCROLLING GALLERY BOARD -->
      <div class="modal-img" id="modalImgContainer" style="display:none">
        <div class="modal-gallery-container">
          <div class="modal-gallery" id="modalGallery"></div>
        </div>
      </div>
      <!-- GALLERY SELECTION VIEW -->
      <div class="modal-inner" id="modalInner"></div>
      <p class="eyebrow" id="modalCat" style="margin-top:22px;margin-bottom:0"></p>
      <h3 id="modalTitle"></h3>
      <p id="modalDesc"></p>
      <p style="color:rgba(255,255,255,.42)">View creative assets and portfolio samples. I combine creative expertise with AI tools to deliver compelling eCommerce solutions.</p>
    </div>
  </div>
  <script>
    const services = [
      ["Product Listing & Merchandising","Product Architecture","I build product listings that are easy to understand, properly organized, visually aligned, and ready for fast-moving eCommerce operations.",["Shopify","Canva Pro","ChatGPT","Sheets"],["Variant accuracy","Stronger product clarity","Premium listing layout"],"LISTING","□"],
      ["AI Ad Creative Production","AI Creative Engine","I create AI-powered Meta ad visuals and creative variations designed for testing, scroll-stopping presentation, and modern paid social campaigns.",["ChatGPT","Claude","Higgsfield","Canva Pro","CapCut"],["Creative angles","Fast variations","Ad-ready assets"],"AI ADS","✦"],
      ["Meta Creative Strategy","Paid Social Thinking","I support Meta creative direction through visual hooks, messaging angles, product-focused creatives, and clean creative testing systems.",["Meta Ads Manager","ChatGPT","Canva Pro"],["Hook-first concepts","Testing structure","Conversion intent"],"META","◐"]
    ];
    // Work cards: [title, category, label, description, coverImage, galleryImages]
    // Add new project cards below with the same 6-item structure.
    const works = [
      ["Variant-Rich Product Listing","Product Listings","Listing","Organized product listing framework with variants, titles, descriptions, product images, and clean backend naming logic.","productlisting.png",["1.jpg","2.jpg","3.jpg","4.jpg"]],
      ["Ad Creative Set","AI Ad Creatives","AI Creative","AI-assisted image ad concepts for Meta campaigns with modern visual hooks and premium fashion positioning.","adcreative.png",[".jpg",".jpg",".jpg",".jpg"]],
      ["Meta Ad Creatives","Meta Ads","Strategy","Creative testing structure for hooks, angles, offers, and product-focused ad iterations.","metacover.png",["5.jpg","6.jpg","7.jpg"]],
    ];
    // ADD OR EDIT PROJECT GALLERIES HERE
    // ADD NEW PROJECT GALLERY HERE
    // To add another project gallery, follow this structure:
    // \"Category Name\": [ { title: \"Gallery Name\", description: \"...\", cover: \"image.png\", images: [\"img1.png\", \"img2.png\", ...] }, ... ]
    const workGalleries = {
      \"Product Listings\": [
        {
          title: \"NOCTRA Studio Product Listing\",
          description: \"Shopify product listing gallery showing product page setup, backend organization, product media, variants, and merchandising details.\",
          cover: \"productlisting.png\",
          // ADD NEW OUTPUT IMAGE HERE - Product Listings Gallery
          // To add another image to this gallery, add a new image path below:
          images: [\"5.jpg\",\"1.jpg\",\"2.jpg\",\"3.jpg\",\"6.jpg\"]
          // ADD NEW OUTPUT IMAGE HERE
          // \"images/product-listing-new.jpg\",
        },
        {
          title: "N/A",
          description: "Coming soon — another Shopify product listing gallery will be added here.",
          cover: "cover.png",
          images: [],
          // EDIT THIS N/A GALLERY LATER
        },
        {
          title: "N/A",
          description: "Coming soon — another Shopify product listing gallery will be added here.",
          cover: "cover.png",
          images: [],
          // EDIT THIS N/A GALLERY LATER
        }
      ],
      "AI Ad Creatives": [
        {
          title: "Ad creative gallery",
          description: "AI ad creative gallery showing campaign visuals, creative hooks, and creative testing assets.",
          cover: "adcreative.png",
          images: ["native.png","native.png","native.png","native.png"]
        },
        {
          title: "N/A",
          description: "Coming soon — another AI Ad Creative gallery will be added here.",
          cover: "native.png",
          images: [],
          // EDIT THIS N/A GALLERY LATER
        },
        {
          title: "N/A",
          description: "Coming soon — another AI Ad Creative gallery will be added here.",
          cover: "native.png",
          images: [],
          // EDIT THIS N/A GALLERY LATER
        }
      ],
      "Meta Ads": [
        {
          title: "Meta Ads Creatives Gallery",
          description: "Meta Ads gallery showing ad sets, campaign messaging, and conversion-ready preview screens.",
          cover: "metacover.png",
          images: ["native1.png","native2.png","native3.png","native4.png","native5.png"]
        },
        {
          title: "N/A",
          description: "Coming soon — another Meta Ads gallery will be added here.",
          cover: "cover.png",
          images: [],
          // EDIT THIS N/A GALLERY LATER
        },
        {
          title: "N/A",
          description: "Coming soon — another Meta Ads gallery will be added here.",
          cover: "cover.png",
          images: [],
          // EDIT THIS N/A GALLERY LATER
        }
      ]
    };
    const categories = ["All Works","Product Listings","AI Ad Creatives","Meta Ads"];
    const tools = [["Shopify & eCommerce",["Shopify","Meta Ads Manager"]],["AI Systems",["ChatGPT","Claude","Higgsfield"]],["Creative Tools",["Canva Pro","CapCut"]],["Productivity",["Notion","Google Workspace"]],["Communication",["Slack"]]];
    let activeService = 0, activeCategory = "All Works";
    let currentModalSlide = 0;
    const serviceList = document.getElementById('serviceList'), showcase = document.getElementById('showcase'), filters = document.getElementById('filters'), workGrid = document.getElementById('workGrid'), toolsGrid = document.getElementById('toolsGrid');
    const modalBack = document.getElementById('modalBack');
    const modalInner = document.getElementById('modalInner');
    const modalImg = document.querySelector('.modal-img');
    const modalIndicators = document.getElementById('modalIndicators');
    document.getElementById('modalGallery')?.addEventListener('scroll', syncModalSlideFromScroll);
    function renderServices(){ serviceList.innerHTML = services.map((s,i)=>`<button class="service-btn ${i===activeService?'active':''}" onclick="activeService=${i};renderServices();renderShowcase();"><span style="display:flex;gap:16px;align-items:center"><span class="service-icon">${s[6]}</span><span><span class="service-kicker">${s[1]}</span><span class="service-title">${s[0]}</span></span></span><span>↗</span></button>`).join(''); }
    function renderShowcase(){ const s=services[activeService]; showcase.innerHTML = `<div class="showcase-visual"><div class="floating-badge"><div style="font-size:24px">${s[6]}</div><p class="service-kicker" style="margin-top:14px">${s[1]}</p></div><h3 class="visual-label">${s[5]}</h3></div><h3>${s[0]}</h3><p>${s[2]}</p><div class="metric-grid">${s[4].map(m=>`<div class="metric">${m}</div>`).join('')}</div><div class="pills">${s[3].map(t=>`<span class="pill">${t}</span>`).join('')}</div>`; }
    function renderFilters(){ filters.innerHTML = categories.map(c=>`<button class="filter-btn ${c===activeCategory?'active':''}" onclick="activeCategory='${c}';renderFilters();renderWorks();">${c}</button>`).join(''); }
    function renderWorks(){ const list = activeCategory==='All Works'?works:works.filter(w=>w[1]===activeCategory); workGrid.innerHTML = list.map((w,i)=>`<button class="spotlight work-card" onclick="openModal(${works.indexOf(w)})"><div class="work-image"><img src="${w[4]}" alt="${w[0]}" class="gallery-img"><span class="pill">${w[2]}</span></div><p class="cat">${w[1]}</p><h3>${w[0]}</h3></button>`).join(''); }
    function renderTools(){ toolsGrid.innerHTML = tools.map(g=>`<div class="spotlight tool-box"><h3>${g[0]}</h3><div class="pills">${g[1].map(t=>`<span class="pill">${t}</span>`).join('')}</div></div>`).join(''); }
    let currentModalCategory = '';
    modalBack.onclick = () => renderGallerySelection(currentModalCategory);
    function setModalView(view) {
      if (view === 'gallery') {
        modalImg.style.display = 'block';
        modalIndicators.style.display = 'flex';
        modalInner.style.display = 'none';
      } else {
        modalImg.style.display = 'none';
        modalIndicators.style.display = 'none';
        modalInner.style.display = 'grid';
      }
    }
    function renderGallerySelection(category) {
      const galleries = workGalleries[category] || [];
      currentModalCategory = category;
      setModalView('selection');
      modalBack.style.display = 'none';
      document.getElementById('modalCat').textContent = category;
      document.getElementById('modalTitle').textContent = category;
      document.getElementById('modalDesc').textContent = `Select a ${category.toLowerCase()} project gallery to preview images, assets, and screenshots.`;
      modalInner.innerHTML = `<div class="product-gallery-grid">${galleries.map((gallery, idx) => `<button class="product-gallery-card" onclick="openWorkGallery(${idx})"><div class="product-gallery-cover"><img src="${gallery.cover}" alt="${gallery.title}"></div><div class="product-gallery-copy"><h4>${gallery.title}</h4><p>${gallery.description}</p><span class="pill">${gallery.images.length ? 'View gallery' : 'Coming soon'}</span></div></button>`).join('')}</div>`;
    }
    function openWorkGallery(index) {
      const galleries = workGalleries[currentModalCategory] || [];
      const gallery = galleries[index];
      if (!gallery) return;
      modalBack.style.display = 'grid';
      document.getElementById('modalCat').textContent = currentModalCategory;
      document.getElementById('modalTitle').textContent = gallery.title;
      document.getElementById('modalDesc').textContent = gallery.description;
      if (!gallery.images.length) {
        setModalView('selection');
        modalInner.innerHTML = `<div class="modal-empty-state"><h4>This gallery will be added soon.</h4><p>Check back later for another ${currentModalCategory.toLowerCase()} gallery with real screenshot detail and project structure.</p></div>`;
        modalIndicators.innerHTML = '';
        modalImg.style.display = 'none';
        return;
      }
      setModalView('gallery');
      const modalGallery = document.getElementById('modalGallery');
      currentModalSlide = 0;
      modalGallery.innerHTML = gallery.images.map(img => `<div class="modal-slide"><img src="${img}" alt="${gallery.title}" class="modal-real-img"></div>`).join('');
      updateModalButtons();
      scrollModalTo(0);
    }
    function updateModalButtons() {
      const gallery = document.getElementById('modalGallery');
      const prev = document.getElementById('modalPrev');
      const next = document.getElementById('modalNext');
      const count = gallery?.children.length || 0;
      if (!gallery) return;
      prev.style.display = next.style.display = count > 1 ? 'grid' : 'none';
      renderModalIndicators(count);
    }
    function renderModalIndicators(count) {
      const indicators = document.getElementById('modalIndicators');
      if (!indicators) return;
      indicators.innerHTML = Array.from({ length: count }, (_, index) => `<span class="${index === currentModalSlide ? 'active' : ''}"></span>`).join('');
    }
    function syncModalSlideFromScroll() {
      const gallery = document.getElementById('modalGallery');
      if (!gallery || !gallery.children.length) return;
      const slideIndex = Math.round(gallery.scrollLeft / gallery.clientWidth);
      if (slideIndex !== currentModalSlide) {
        currentModalSlide = slideIndex;
        renderModalIndicators(gallery.children.length);
      }
    }
    function scrollModalTo(index) {
      const gallery = document.getElementById('modalGallery');
      if (!gallery || !gallery.children[index]) return;
      currentModalSlide = index;
      gallery.scrollTo({ left: gallery.children[index].offsetLeft, behavior: 'smooth' });
      updateModalButtons();
    }
    function openModal(i){
      const w = works[i];
      document.getElementById('modalCat').textContent = w[1];
      document.getElementById('modalTitle').textContent = w[0];
      document.getElementById('modalDesc').textContent = w[3];
      modalBack.style.display = 'none';
      modalInner.innerHTML = '';
      document.getElementById('modal').classList.add('show');
      if (workGalleries[w[1]]) {
        renderGallerySelection(w[1]);
        return;
      }
      setModalView('gallery');
      const modalImages = Array.isArray(w[5]) && w[5].length ? w[5] : [w[4]];
      const gallery = document.getElementById('modalGallery');
      currentModalSlide = 0;
      gallery.innerHTML = modalImages.map(img => `<div class="modal-slide"><img src="${img}" alt="${w[0]}" class="modal-real-img"></div>`).join('');
      updateModalButtons();
      scrollModalTo(0);
    }
    document.getElementById('modalPrev').onclick = () => scrollModalTo(Math.max(0, currentModalSlide - 1));
    document.getElementById('modalNext').onclick = () => {
      const gallery = document.getElementById('modalGallery');
      scrollModalTo(Math.min((gallery?.children.length || 1) - 1, currentModalSlide + 1));
    };
    document.getElementById('closeModal').onclick = () => document.getElementById('modal').classList.remove('show');
    document.getElementById('closeModal').onclick=()=>document.getElementById('modal').classList.remove('show');
    document.getElementById('modal').onclick=e=>{ if(e.target.id==='modal') e.currentTarget.classList.remove('show'); };
    function reveal(){ document.querySelectorAll('.reveal').forEach(el=>{ if(el.getBoundingClientRect().top < innerHeight*.85) el.classList.add('show'); }); }
    addEventListener('scroll',()=>{ const h=document.documentElement.scrollHeight-innerHeight; document.getElementById('progress').style.width=(scrollY/h*100)+'%'; reveal(); });
    addEventListener('load',()=>{ setTimeout(()=>document.getElementById('loader').classList.add('hide'),850); reveal(); renderServices(); renderShowcase(); renderFilters(); renderWorks(); renderTools(); });
  </script>
</body>
</html>
